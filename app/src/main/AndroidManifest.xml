<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TimberTrade"
        android:usesCleartextTraffic="true">
        
        <!-- Real Dashboard Activity -->
        <activity
            android:name=".dashboard.RealDashboardActivity"
            android:exported="true"
            android:theme="@android:style/Theme.Light.NoTitleBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <!-- Marketplace Activity -->
        <activity
            android:name=".marketplace.MarketplaceActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Light.NoTitleBar" />
        
        <!-- New Order Activity -->
        <activity
            android:name=".orders.NewOrderActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Light.NoTitleBar" />
        
        <!-- Inventory Activity -->
        <activity
            android:name=".inventory.InventoryActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Light.NoTitleBar" />
        
        <!-- Reports Activity -->
        <activity
            android:name=".reports.ReportsActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Light.NoTitleBar" />
        
        <!-- Clean Dashboard Activity -->
        <activity
            android:name=".dashboard.CleanDashboardActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Light.NoTitleBar" />
        
        <!-- Main Dashboard Activity -->
        <activity
            android:name=".dashboard.DashboardActivity"
            android:exported="false"
            android:theme="@style/Theme.TimberTrade" />
        
        <!-- Authentication Activities (Disabled) -->
        <activity
            android:name=".auth.LoginActivity"
            android:exported="false"
            android:theme="@style/Theme.TimberTrade" />
        
        <activity
            android:name=".auth.SignupActivity"
            android:exported="false"
            android:theme="@style/Theme.TimberTrade" />
        
        <!-- Simple Dashboard Activity (Fallback) -->
        <activity
            android:name=".dashboard.SimpleDashboardActivity"
            android:exported="false"
            android:theme="@style/Theme.TimberTrade" />

    </application>

</manifest>