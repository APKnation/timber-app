<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/timber_background"
    tools:context=".dashboard.BuyerDashboardFragment">

    <!-- Header Section - RelativeLayout for positioning -->
    <RelativeLayout
        android:id="@+id/headerSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:padding="16dp"
        android:background="@color/timber_primary">

        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"
            android:text="Welcome, Buyer!"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvWelcome"
            android:layout_alignParentStart="true"
            android:layout_marginTop="4dp"
            android:text="Browse premium timber from trusted sellers"
            android:textColor="@color/timber_primary_light"
            android:textSize="14sp" />

        <!-- Profile Icon positioned at top right -->
        <ImageView
            android:id="@+id/ivProfile"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_profile"
            android:background="@drawable/circle_background"
            android:padding="8dp"
            android:contentDescription="Profile" />

    </RelativeLayout>

    <!-- Scrollable Content Area -->
    <ScrollView
        android:id="@+id/contentScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/headerSection"
        android:layout_above="@id/bottomActions"
        android:fillViewport="true"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Quick Stats - LinearLayout for equal distribution -->
            <LinearLayout
                android:id="@+id/statsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp"
                android:weightSum="2">

                <!-- Active Listings Card -->
                <RelativeLayout
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/stats_card_background">

                    <TextView
                        android:id="@+id/tvActiveListings"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerHorizontal="true"
                        android:layout_marginTop="16dp"
                        android:text="150"
                        android:textColor="@color/timber_primary"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/tvActiveListings"
                        android:layout_centerHorizontal="true"
                        android:text="Active Listings"
                        android:textColor="@color/timber_text_secondary"
                        android:textSize="12sp" />

                </RelativeLayout>

                <!-- Live Auctions Card -->
                <RelativeLayout
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/stats_card_background">

                    <TextView
                        android:id="@+id/tvActiveAuctions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerHorizontal="true"
                        android:layout_marginTop="16dp"
                        android:text="25"
                        android:textColor="@color/timber_secondary"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/tvActiveAuctions"
                        android:layout_centerHorizontal="true"
                        android:text="Live Auctions"
                        android:textColor="@color/timber_text_secondary"
                        android:textSize="12sp" />

                </RelativeLayout>

            </LinearLayout>

            <!-- Featured Products Section - RelativeLayout for title positioning -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvFeaturedTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_alignParentTop="true"
                    android:text="Featured Products"
                    android:textColor="@color/timber_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvViewAllProducts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="View All →"
                    android:textColor="@color/timber_primary"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackgroundBorderless" />

                <!-- Products RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvFeaturedProducts"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_below="@id/tvFeaturedTitle"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    tools:listitem="@layout/item_product_card" />

            </RelativeLayout>

            <!-- Live Auctions Section - RelativeLayout for title positioning -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvAuctionsTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_alignParentTop="true"
                    android:text="Live Auctions"
                    android:textColor="@color/timber_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvViewAllAuctions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="View All →"
                    android:textColor="@color/timber_primary"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackgroundBorderless" />

                <!-- Auctions RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvLiveAuctions"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_below="@id/tvAuctionsTitle"
                    android:layout_marginTop="12dp"
                    tools:listitem="@layout/item_auction_card" />

            </RelativeLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Bottom Actions - RelativeLayout for fixed positioning -->
    <LinearLayout
        android:id="@+id/bottomActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@color/timber_surface"
        android:elevation="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSearchProducts"
            style="@style/PrimaryButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Search Products" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewOrders"
            style="@style/SecondaryButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="My Orders" />

    </LinearLayout>

</RelativeLayout>
